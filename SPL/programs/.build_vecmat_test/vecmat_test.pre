# ============================================================================
# stdlib/vecmat.atl — Biblioteca de Vectores y Matrices de Atlas SPL
# ============================================================================
#
# Uso:
#     #include <vecmat.atl>
#
# Convencion de almacenamiento (8 bytes / 64 bits por dato):
#
#   VECTOR (longitud N):
#       v[0]            = N            (cabecera con la longitud)
#       v[1] .. v[N]    = elementos    (N datos contiguos)
#       --> el usuario debe declarar  int v[N + 1];
#
#   MATRIZ (filas R x columnas C):
#       m[0]            = R            (cabecera fila 0)
#       m[1]            = C            (cabecera fila 1)
#       m[2] .. m[1+R*C]= datos en row-major
#       --> el usuario debe declarar  int m[R * C + 2];
#
# Las funciones reciben los arreglos como punteros (sintaxis  int v[]) y
# operan sobre la memoria del usuario sin copias.
# ============================================================================
# ----------------------------------------------------------------------------
# VECTORES
# ----------------------------------------------------------------------------
# Inicializa la cabecera del vector con la longitud N.
void vec_init(int v[], int n) {
    v[0] = n;
}
# Devuelve la longitud almacenada en la cabecera.
int vec_len(int v[]) {
    return v[0];
}
# Lee el elemento en la posicion i (0-based).
int vec_get(int v[], int i) {
    return v[i + 1];
}
# Escribe el elemento en la posicion i.
void vec_set(int v[], int i, int val) {
    v[i + 1] = val;
}
# Rellena los N elementos con un valor fijo.
void vec_fill(int v[], int val) {
    int n = v[0];
    int i = 0;
    while (i < n) {
        v[i + 1] = val;
        i = i + 1;
    }
}
# Suma todos los elementos.
int vec_sum(int v[]) {
    int n = v[0];
    int s = 0;
    int i = 0;
    while (i < n) {
        s = s + v[i + 1];
        i = i + 1;
    }
    return s;
}
# Producto punto (asume misma longitud almacenada en a).
int vec_dot(int a[], int b[]) {
    int n = a[0];
    int s = 0;
    int i = 0;
    while (i < n) {
        s = s + a[i + 1] * b[i + 1];
        i = i + 1;
    }
    return s;
}
# Suma elemento a elemento: a[i] = a[i] + b[i].
void vec_add(int a[], int b[]) {
    int n = a[0];
    int i = 0;
    while (i < n) {
        a[i + 1] = a[i + 1] + b[i + 1];
        i = i + 1;
    }
}
# Resta elemento a elemento: a[i] = a[i] - b[i].
void vec_sub(int a[], int b[]) {
    int n = a[0];
    int i = 0;
    while (i < n) {
        a[i + 1] = a[i + 1] - b[i + 1];
        i = i + 1;
    }
}
# Escala todos los elementos por una constante k.
void vec_scale(int v[], int k) {
    int n = v[0];
    int i = 0;
    while (i < n) {
        v[i + 1] = v[i + 1] * k;
        i = i + 1;
    }
}
# Devuelve el maximo de los elementos (vector no vacio).
int vec_max(int v[]) {
    int n = v[0];
    int m = v[1];
    int i = 1;
    while (i < n) {
        if (v[i + 1] > m) {
            m = v[i + 1];
        }
        i = i + 1;
    }
    return m;
}
# Devuelve el minimo de los elementos (vector no vacio).
int vec_min(int v[]) {
    int n = v[0];
    int m = v[1];
    int i = 1;
    while (i < n) {
        if (v[i + 1] < m) {
            m = v[i + 1];
        }
        i = i + 1;
    }
    return m;
}
# Copia src sobre dst (incluyendo la cabecera).
void vec_copy(int dst[], int src[]) {
    int n = src[0];
    dst[0] = n;
    int i = 0;
    while (i < n) {
        dst[i + 1] = src[i + 1];
        i = i + 1;
    }
}
# Imprime los elementos del vector uno por linea.
void vec_print(int v[]) {
    int n = v[0];
    int i = 0;
    while (i < n) {
        print(v[i + 1]);
        i = i + 1;
    }
}
# ----------------------------------------------------------------------------
# MATRICES (almacenamiento row-major con cabecera de 2 enteros)
# ----------------------------------------------------------------------------
# Escribe la cabecera (filas, columnas).
void mat_init(int m[], int rows, int cols) {
    m[0] = rows;
    m[1] = cols;
}
# Numero de filas.
int mat_rows(int m[]) {
    return m[0];
}
# Numero de columnas.
int mat_cols(int m[]) {
    return m[1];
}
# Lee m[i][j].
int mat_get(int m[], int i, int j) {
    int cols = m[1];
    return m[i * cols + j + 2];
}
# Escribe m[i][j] = val.
void mat_set(int m[], int i, int j, int val) {
    int cols = m[1];
    m[i * cols + j + 2] = val;
}
# Rellena toda la matriz con un valor fijo.
void mat_fill(int m[], int val) {
    int rows = m[0];
    int cols = m[1];
    int total = rows * cols;
    int k = 0;
    while (k < total) {
        m[k + 2] = val;
        k = k + 1;
    }
}
# Multiplicacion de matrices: c = a * b.
# Requiere que cols(a) == rows(b). c se inicializa con (rows(a), cols(b)).
void mat_mul(int a[], int b[], int c[]) {
    int ar = a[0];
    int ac = a[1];
    int bc = b[1];
    c[0] = ar;
    c[1] = bc;
    int i = 0;
    while (i < ar) {
        int j = 0;
        while (j < bc) {
            int acc = 0;
            int k = 0;
            while (k < ac) {
                acc = acc + a[i * ac + k + 2] * b[k * bc + j + 2];
                k = k + 1;
            }
            c[i * bc + j + 2] = acc;
            j = j + 1;
        }
        i = i + 1;
    }
}
# Imprime la matriz fila por fila (cada elemento en una linea).
void mat_print(int m[]) {
    int rows = m[0];
    int cols = m[1];
    int i = 0;
    while (i < rows) {
        int j = 0;
        while (j < cols) {
            print(m[i * cols + j + 2]);
            j = j + 1;
        }
        i = i + 1;
    }
}
# ============================================================================
# Test exhaustivo de la biblioteca vecmat.atl.
# Cada print muestra el valor calculado y al lado se anota el esperado.
# ============================================================================
int main() {
    # ── Vector v de longitud 5 ──────────────────────────────────────────
    int v[6];
    vec_init(v, 5);
    vec_fill(v, 0);
    print(vec_len(v));      # 5
    vec_set(v, 0, 10);
    vec_set(v, 1, 20);
    vec_set(v, 2, 30);
    vec_set(v, 3, 40);
    vec_set(v, 4, 50);
    print(vec_get(v, 0));   # 10
    print(vec_get(v, 4));   # 50
    print(vec_sum(v));      # 150
    print(vec_max(v));      # 50
    print(vec_min(v));      # 10
    # ── Vector w (copia + escala) ───────────────────────────────────────
    int w[6];
    vec_copy(w, v);
    print(vec_len(w));      # 5
    print(vec_sum(w));      # 150
    vec_scale(w, 2);
    print(vec_get(w, 0));   # 20
    print(vec_get(w, 4));   # 100
    print(vec_sum(w));      # 300
    # ── Producto punto ──────────────────────────────────────────────────
    # v . v = 100 + 400 + 900 + 1600 + 2500 = 5500
    print(vec_dot(v, v));
    # ── Suma de vectores: v += v  ⇒ duplicar v ─────────────────────────
    vec_add(v, v);
    print(vec_get(v, 0));   # 20
    print(vec_get(v, 4));   # 100
    print(vec_sum(v));      # 300
    # ── Resta: v -= w  ⇒ v queda en 0  (v=300, w=300) ──────────────────
    vec_sub(v, w);
    print(vec_sum(v));      # 0
    # ── Matriz 2x3 A ────────────────────────────────────────────────────
    #   1 2 3
    #   4 5 6
    int A[8];           # 2*3 + 2 = 8
    mat_init(A, 2, 3);
    mat_set(A, 0, 0, 1); mat_set(A, 0, 1, 2); mat_set(A, 0, 2, 3);
    mat_set(A, 1, 0, 4); mat_set(A, 1, 1, 5); mat_set(A, 1, 2, 6);
    print(mat_rows(A));     # 2
    print(mat_cols(A));     # 3
    print(mat_get(A, 0, 0));# 1
    print(mat_get(A, 1, 2));# 6
    # ── Matriz 3x2 B ────────────────────────────────────────────────────
    #   7  8
    #   9  10
    #  11  12
    int B[8];
    mat_init(B, 3, 2);
    mat_set(B, 0, 0, 7);  mat_set(B, 0, 1, 8);
    mat_set(B, 1, 0, 9);  mat_set(B, 1, 1, 10);
    mat_set(B, 2, 0, 11); mat_set(B, 2, 1, 12);
    # ── C = A * B  (2x2) ────────────────────────────────────────────────
    #   1*7+2*9+3*11   1*8+2*10+3*12   =   58   64
    #   4*7+5*9+6*11   4*8+5*10+6*12   =  139  154
    int C[6];
    mat_mul(A, B, C);
    print(mat_rows(C));         # 2
    print(mat_cols(C));         # 2
    print(mat_get(C, 0, 0));    # 58
    print(mat_get(C, 0, 1));    # 64
    print(mat_get(C, 1, 0));    # 139
    print(mat_get(C, 1, 1));    # 154
    # ── mat_fill ────────────────────────────────────────────────────────
    int F[6];
    mat_init(F, 2, 2);
    mat_fill(F, 7);
    print(mat_get(F, 0, 0));    # 7
    print(mat_get(F, 1, 1));    # 7
    return 0;
}
